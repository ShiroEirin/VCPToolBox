{
  "name": "FRPSInfoProvider",
  "displayName": "FRPS 设备信息提供器",
  "version": "1.0.0",
  "pluginType": "static",
  "description": "定期从FRPS服务器获取所有类型的代理设备信息",
  "author": "VCP Team",
  "enabled": true,
  "entry": "main.py",
  "runtime": "python",
  "systemPromptPlaceholders": [
    "{{FRPSAllProxyInfo}}"
  ],
  "config": {
    "refreshInterval": 300,
    "timeout": 30
  }
}
