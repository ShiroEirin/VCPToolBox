{
  "name": "1PanelInfoProvider",
  "displayName": "1Panel 信息提供器",
  "version": "1.0.0",
  "pluginType": "static",
  "description": "从1Panel服务器获取Dashboard基础信息和操作系统信息",
  "author": "VCP Team",
  "enabled": true,
  "entry": "main.py",
  "runtime": "python",
  "systemPromptPlaceholders": [
    "{{1PanelDashboard}}",
    "{{1PanelOsInfo}}"
  ],
  "config": {
    "refreshInterval": 300,
    "timeout": 30
  }
}
